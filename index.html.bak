<section id="network-trace" class="trace-section">
<div class="container">
<div class="section-label reveal" data-i18n="trace_label">Flagship Feature</div>
<div class="section-title reveal" data-i18n="trace_title">Network Trace</div>
<div class="section-sub reveal" data-i18n="trace_sub">Enter a name. Uncover the entire network.</div>

<div class="trace-demo reveal">
<!-- Simulated search bar -->
<div class="trace-search" id="traceSearch">
<span class="search-icon">🔍</span>
<span id="traceTyped"></span><span class="trace-cursor" id="traceCursor"></span>
</div>

<!-- Scenario indicator -->
<div class="trace-scenario-indicator" id="traceIndicator">
<span class="trace-dot active" id="traceDot0"></span>
<span class="trace-dot" id="traceDot1"></span>
<span class="trace-dot" id="traceDot2"></span>
</div>

<!-- Animated network graph — dynamically populated by JS -->
<div class="trace-graph" id="traceGraph">
<svg class="trace-lines" id="traceLines" xmlns="http://www.w3.org/2000/svg"></svg>
</div>

<!-- Detection badges -->
<div class="trace-detect" id="traceDetect1"><span id="traceBadgeText"></span></div>
<div class="trace-detect trace-detect-secondary" id="traceDetect2">
<span id="traceRiskLabel">Risk Score: </span><strong id="traceRiskNum">0</strong><span>/100</span>
</div>
<div class="trace-detect trace-detect-sar" id="traceDetect3">
<span data-i18n="trace_sar">📋 SAR Recommended — Auto-generated</span>
</div>
</div>

<!-- Capability cards -->
<div class="trace-capabilities">
<div class="trace-cap-card reveal">
<span class="cap-emoji">🌐</span>
<h4 data-i18n="trace_cap1_title">Auto-Expand</h4>
<p data-i18n="trace_cap1_desc">One seed entity reveals the full network. No manual digging required.</p>
</div>
<div class="trace-cap-card reveal">
<span class="cap-emoji">🔗</span>
<h4 data-i18n="trace_cap2_title">Path Finding</h4>
<p data-i18n="trace_cap2_desc">Find hidden connections between any two entities. Up to 4-hop BFS traversal.</p>
</div>
<div class="trace-cap-card reveal">
<span class="cap-emoji">🎯</span>
<h4 data-i18n="trace_cap3_title">Pattern Detection</h4>
<p data-i18n="trace_cap3_desc">25+ AML/CFT patterns detected automatically as the network builds.</p>
</div>
<div class="trace-cap-card reveal">
<span class="cap-emoji">⏱️</span>
<h4 data-i18n="trace_cap4_title">Time Analysis</h4>
<p data-i18n="trace_cap4_desc">Filter by date range. Watch how criminal networks evolve over time.</p>
</div>
</div>

</div>
</section>
<div class="section-divider"></div>


<!-- INVESTIGATION SCENARIOS -->
<section id="scenarios" class="scenarios-section">
<div class="scenarios-header">
<div class="label" data-i18n="scenarios_label">Investigation Scenarios</div>
<h2 data-i18n="scenarios_title">See Layer.ONE in Action</h2>
<p data-i18n="scenarios_subtitle">Real-world scenarios showing how Layer.ONE transforms raw data into actionable intelligence — from first alert to case resolution.</p>
</div>

<div class="scenario-tabs reveal">
<button class="scenario-tab active" data-scenario="1" data-i18n="sc1_tab">🔍 Hidden Laundering</button>
<button class="scenario-tab" data-scenario="2" data-i18n="sc2_tab">🧾 Invoice Fraud</button>
<button class="scenario-tab" data-scenario="3" data-i18n="sc3_tab">👥 Mule Network</button>
</div>

<div class="scenario-panels" id="scenarioPanels">

<!-- ═══ SCENARIO 1: Hidden Laundering Network ═══ -->
<div class="scenario-panel active" data-scenario-panel="1">
<div class="scenario-title-bar">
<div class="sc-label" data-i18n="sc1_label">Investigation Scenario 01</div>
<h3 data-i18n="sc1_title">A Hidden Laundering Network</h3>
<div class="sc-desc" data-i18n="sc1_desc">What begins as a routine wire transfer reveals a coordinated financial crime operation spanning 3 countries and 14 accounts.</div>
</div>

<div class="steps-flow">

<!-- STEP 1 -->
<div class="step-card">
<div class="step-num">1</div>
<h4 data-i18n="sc1_s1_title">Initial Transaction</h4>
<p class="step-desc" data-i18n="sc1_s1_desc">A mid-size wire transfer enters the system. Nothing unusual at first glance.</p>
<div class="step-mockup">
<div class="mock-label">Transaction Monitor</div>
<div class="mock-row"><span class="mock-key">TX ID</span><span class="mock-val">TRX-9F28X7</span></div>
<div class="mock-row"><span class="mock-key">Amount</span><span class="mock-val">$48,250.00</span></div>
<div class="mock-row"><span class="mock-key">From</span><span class="mock-val">Meridian Holdings LLC</span></div>
<div class="mock-row"><span class="mock-key">To</span><span class="mock-val">Apex Trading FZE</span></div>
<div class="mock-row"><span class="mock-key">Route</span><span class="mock-val">US → UAE → Turkey</span></div>
<div class="mock-row"><span class="mock-key">Time</span><span class="mock-val">10:24:19</span></div>
<div class="mock-row"><span class="mock-key">Risk Score</span><span class="mock-val">23 <span class="mock-badge low">Low Risk</span></span></div>
<div style="margin-top:auto;padding-top:8px;display:flex;align-items:center;gap:6px;font-size:.6rem;color:var(--muted)">
<span style="font-size:.8rem">🏦</span><span>────────</span><span style="font-size:.8rem">🏦</span>
</div>
</div>
<div class="step-status"><span class="dot blue"></span> Transaction ingested</div>
</div>

<!-- STEP 2 -->
<div class="step-card">
<div class="step-num">2</div>
<h4 data-i18n="sc1_s2_title">Hidden Connections Appear</h4>
<p class="step-desc" data-i18n="sc1_s2_desc">Layer.ONE links the sender to multiple accounts, shell companies, and previously flagged entities across jurisdictions.</p>
<div class="step-mockup">
<div class="mock-label">Entity Graph</div>
<div class="graph-container">
<svg style="position:absolute;inset:0;width:100%;height:100%;z-index:1" xmlns="http://www.w3.org/2000/svg">
<!-- Center to accounts -->
<line x1="50%" y1="50%" x2="14%" y2="22%" stroke="rgba(0,212,255,.2)" stroke-width="1"/>
<line x1="50%" y1="50%" x2="81%" y2="17%" stroke="rgba(0,212,255,.2)" stroke-width="1"/>
<line x1="50%" y1="50%" x2="11%" y2="77%" stroke="rgba(0,212,255,.2)" stroke-width="1"/>
<line x1="50%" y1="50%" x2="88%" y2="72%" stroke="rgba(0,212,255,.2)" stroke-width="1"/>
<!-- Center to companies -->
<line x1="50%" y1="50%" x2="36%" y2="12%" stroke="rgba(245,158,11,.2)" stroke-width="1"/>
<line x1="50%" y1="50%" x2="71%" y2="85%" stroke="rgba(245,158,11,.2)" stroke-width="1"/>
<line x1="50%" y1="50%" x2="26%" y2="92%" stroke="rgba(245,158,11,.2)" stroke-width="1"/>
<!-- Center to persons -->
<line x1="50%" y1="50%" x2="81%" y2="47%" stroke="rgba(16,185,129,.2)" stroke-width="1"/>
<line x1="50%" y1="50%" x2="21%" y2="49%" stroke="rgba(16,185,129,.2)" stroke-width="1"/>
<!-- Center to device -->
<line x1="50%" y1="50%" x2="56%" y2="97%" stroke="rgba(167,139,250,.2)" stroke-width="1"/>
<!-- Cross connections (secondary) -->
<line x1="14%" y1="22%" x2="36%" y2="12%" stroke="rgba(148,163,184,.1)" stroke-width="1" stroke-dasharray="3,3"/>
<line x1="81%" y1="17%" x2="81%" y2="47%" stroke="rgba(148,163,184,.1)" stroke-width="1" stroke-dasharray="3,3"/>
<line x1="26%" y1="92%" x2="11%" y2="77%" stroke="rgba(148,163,184,.1)" stroke-width="1" stroke-dasharray="3,3"/>
<line x1="71%" y1="85%" x2="88%" y2="72%" stroke="rgba(148,163,184,.1)" stroke-width="1" stroke-dasharray="3,3"/>
<line x1="21%" y1="49%" x2="14%" y2="22%" stroke="rgba(148,163,184,.1)" stroke-width="1" stroke-dasharray="3,3"/>
</svg>
<!-- Center node (flagged) -->
<div class="graph-node flagged center" style="left:calc(50% - 14px);top:calc(50% - 14px)" title="Meridian Holdings LLC">⚠</div>
<!-- Account nodes -->
<div class="graph-node account" style="left:8%;top:15%" title="Account ****3921">A</div>
<div class="graph-node account" style="left:75%;top:10%" title="Account ****8812">A</div>
