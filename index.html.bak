<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Layer.ONE — Financial Crime Intelligence Platform</title>
<style>

:root{
--bg:#0A0E17;--surface:#111827;--border:#1E293B;
--text:#F1F5F9;--muted:#94A3B8;--accent:#00D4FF;
--accent2:#0EA5E9;--accentGlow:rgba(0,212,255,.15);
--danger:#EF4444;--success:#10B981;--warning:#F59E0B;
--font:'Inter','SF Pro Display',-apple-system,sans-serif;
--mono:'JetBrains Mono','SF Mono',monospace;
--radius:8px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{background:var(--bg);color:var(--text);font-family:var(--font);
line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:var(--accent);text-decoration:none}

/* ── SCENARIOS ── */
.scenarios-section{padding:100px 24px;max-width:1400px;margin:0 auto}
.scenarios-header{text-align:center;margin-bottom:48px}
.scenarios-header .label{font-size:.8rem;text-transform:uppercase;letter-spacing:3px;color:var(--accent);margin-bottom:8px}
.scenarios-header h2{font-size:2.2rem;font-weight:700;margin-bottom:12px}
.scenarios-header p{color:var(--muted);max-width:600px;margin:0 auto}

/* Carousel */
.scenario-panels{position:relative}
.scenario-panel{display:none;padding:0 8px;box-sizing:border-box}
.scenario-panel.active{display:block}
.scenario-tabs{display:flex;justify-content:center;gap:12px;margin-bottom:32px;flex-wrap:wrap}
.scenario-tab{padding:10px 20px;border-radius:6px;background:var(--surface);
border:1px solid var(--border);color:var(--muted);cursor:pointer;font-size:.85rem;font-weight:500;transition:all .3s;font-family:var(--font)}
.scenario-tab.active,.scenario-tab:hover{border-color:var(--accent);
color:var(--accent);background:rgba(0,212,255,.05)}

/* Scenario card */
.scenario-title-bar{text-align:center;margin-bottom:40px}
.scenario-title-bar .sc-label{font-size:.75rem;text-transform:uppercase;letter-spacing:3px;color:var(--accent);margin-bottom:8px}
.scenario-title-bar h3{font-size:1.8rem;font-weight:700;margin-bottom:8px}
.scenario-title-bar .sc-desc{color:var(--muted);font-size:.95rem;max-width:700px;margin:0 auto}

/* 5-step flow */
.steps-flow{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:40px;position:relative}
.step-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
padding:20px 16px;display:flex;flex-direction:column;position:relative;transition:border-color .3s}
.step-card:hover{border-color:rgba(0,212,255,.3)}

.step-num{width:32px;height:32px;border-radius:50%;background:var(--accent);color:var(--bg);
font-weight:700;font-size:.85rem;display:flex;align-items:center;justify-content:center;margin-bottom:12px;flex-shrink:0}

.step-card h4{font-size:.9rem;font-weight:700;margin-bottom:6px;line-height:1.3}
.step-card .step-desc{font-size:.8rem;color:var(--muted);line-height:1.5;margin-bottom:16px}

/* Step arrow between cards */
.step-card:not(:last-child)::after{content:'›';position:absolute;right:-12px;top:50%;
transform:translateY(-50%);color:var(--accent);font-size:1.4rem;font-weight:700;z-index:2}

/* Mockup area inside step */
.step-mockup{flex:1;background:rgba(10,14,23,.6);border:1px solid var(--border);
border-radius:6px;padding:12px;font-size:.7rem;min-height:180px;display:flex;flex-direction:column}

/* Step status line */
.step-status{display:flex;align-items:center;gap:6px;margin-top:12px;font-size:.7rem;color:var(--muted)}
.step-status .dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.step-status .dot.blue{background:var(--accent)}
.step-status .dot.green{background:var(--success)}
.step-status .dot.red{background:var(--danger)}
.step-status .dot.purple{background:#A78BFA}

/* Mockup internals */
.mock-label{font-size:.6rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:8px;font-weight:600}
.mock-row{display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid rgba(30,41,59,.5);gap:8px}
.mock-row:last-child{border:none}
.mock-key{color:var(--muted);white-space:nowrap;flex-shrink:0}
.mock-val{color:var(--text);font-family:var(--mono);font-size:.7rem;text-align:right}
.mock-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:.6rem;font-weight:600}
.mock-badge.low{background:rgba(16,185,129,.15);color:var(--success)}
.mock-badge.high{background:rgba(239,68,68,.15);color:var(--danger)}
.mock-badge.critical{background:rgba(239,68,68,.2);color:#FF6B6B}

/* Risk score big number */
.risk-big{font-size:2.2rem;font-weight:800;font-family:var(--mono);line-height:1}
.risk-big.critical{color:var(--danger)}

/* Alert box */
.mock-alert{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);
border-radius:6px;padding:8px;margin-top:8px;font-size:.65rem}
.mock-alert .alert-icon{color:var(--danger);font-weight:700}

/* Evidence list */
.evidence-row{display:flex;justify-content:space-between;align-items:center;padding:3px 0;font-size:.65rem}
.evidence-row .ev-icon{width:14px;height:14px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:.5rem;margin-right:6px}

/* SAR button */
.mock-btn{display:inline-block;padding:4px 12px;background:var(--accent);color:var(--bg);
border-radius:4px;font-size:.6rem;font-weight:600;cursor:default;margin-top:4px}

/* Scenario summary bar */
.scenario-summary{display:flex;align-items:center;gap:32px;padding:32px;
background:var(--surface);border:1px solid var(--border);border-radius:var(--radius)}
.scenario-summary .sum-text{flex:1;min-width:280px}
.scenario-summary .sum-text h4{font-size:1.2rem;font-weight:700;margin-bottom:8px}
.scenario-summary .sum-text p{font-size:.85rem;color:var(--muted);line-height:1.6}
.sum-features{display:flex;gap:24px;flex-wrap:wrap;flex:2}
.sum-feature{text-align:center;min-width:120px}
.sum-feature .sf-icon{font-size:1.5rem;margin-bottom:4px;color:var(--accent)}
.sum-feature .sf-title{font-size:.75rem;font-weight:600;margin-bottom:2px}
.sum-feature .sf-desc{font-size:.75rem;color:var(--muted)}

/* Graph nodes (CSS-drawn) */
.graph-container{position:relative;width:100%;height:130px}
.graph-node{position:absolute;width:22px;height:22px;border-radius:50%;display:flex;
align-items:center;justify-content:center;font-size:.45rem;font-weight:700;
border:2px solid;z-index:2}
.graph-node.account{background:rgba(0,212,255,.15);border-color:var(--accent);color:var(--accent)}
.graph-node.company{background:rgba(245,158,11,.15);border-color:var(--warning);color:var(--warning)}
.graph-node.person{background:rgba(16,185,129,.15);border-color:var(--success);color:var(--success)}
.graph-node.flagged{background:rgba(239,68,68,.2);border-color:var(--danger);color:var(--danger)}
.graph-node.device{background:rgba(167,139,250,.15);border-color:#A78BFA;color:#A78BFA}
.graph-node.center{width:28px;height:28px;font-size:.5rem;box-shadow:0 0 12px rgba(239,68,68,.4)}
.graph-line{position:absolute;height:1px;background:rgba(148,163,184,.2);z-index:1;transform-origin:left center}

/* Responsive */
@media(max-width:1024px){
.steps-flow{grid-template-columns:repeat(3,1fr)}
.step-card:nth-child(3)::after{display:none}
.scenario-summary{flex-direction:column;text-align:center}
}
@media(max-width:768px){
.steps-flow{grid-template-columns:1fr}
.step-card::after{display:none!important}
.scenario-summary{padding:20px}
.sum-features{justify-content:center}
.scenario-tabs{gap:6px}
.scenario-tab{padding:8px 14px;font-size:.8rem}
}


.nav{position:fixed;top:0;left:0;width:100%;z-index:1000;
background:rgba(10,14,23,.85);backdrop-filter:blur(16px);
border-bottom:1px solid var(--border);transition:background .3s}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;
align-items:center;justify-content:space-between;padding:0 24px;height:64px}
.nav-logo{font-weight:700;font-size:1.25rem;letter-spacing:0;
color:var(--text);font-family:var(--mono);display:flex;align-items:baseline;gap:0;cursor:pointer}
.nav-logo .logo-layer{color:var(--text);font-weight:300;letter-spacing:1px}
.nav-logo .logo-dot{color:var(--accent);font-weight:700;margin:0 1px}
.nav-logo .logo-one{color:var(--accent);font-weight:700;letter-spacing:1px}
.nav-logo span.logo-sub{color:var(--muted);font-weight:400;margin-left:10px;font-size:.7rem;font-family:var(--font);letter-spacing:.5px;opacity:.7}
.nav-right{display:flex;align-items:center;gap:20px}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{color:var(--muted);font-size:.85rem;font-weight:500;
transition:color .2s;letter-spacing:.3px;white-space:nowrap}
.nav-links a:hover,.nav-links a.active{color:var(--accent)}

/* Language Selector */
.lang-selector{position:relative}
.lang-btn{background:var(--surface);border:1px solid var(--border);border-radius:6px;
padding:6px 12px;color:var(--text);font-size:.8rem;cursor:pointer;display:flex;
align-items:center;gap:6px;transition:border-color .2s}
.lang-btn:hover{border-color:var(--accent)}
.lang-btn .flag{font-size:1rem}
.lang-btn .arrow{font-size:.6rem;color:var(--muted);transition:transform .2s}
.lang-selector:focus-within .lang-btn .arrow,.lang-selector.open .lang-btn .arrow{transform:rotate(180deg)}
.lang-dropdown{position:absolute;top:calc(100% + 6px);right:0;background:var(--surface);
border:1px solid var(--border);border-radius:6px;overflow:hidden;display:none;
min-width:150px;box-shadow:0 8px 32px rgba(0,0,0,.4);z-index:100}
.lang-selector:focus-within .lang-dropdown,.lang-selector.open .lang-dropdown{display:block}
.lang-option{padding:10px 14px;display:flex;align-items:center;gap:8px;
font-size:.85rem;cursor:pointer;transition:background .2s;color:var(--text)}
.lang-option:hover{background:rgba(0,212,255,.06)}
.lang-option.active{color:var(--accent);background:rgba(0,212,255,.04)}
.lang-option .flag{font-size:1.1rem}

.nav-toggle{display:none;background:none;border:none;color:var(--text);
font-size:1.5rem;cursor:pointer}

@media(max-width:768px){
.nav-links{display:none;position:absolute;top:64px;left:0;width:100%;
flex-direction:column;background:rgba(10,14,23,.97);padding:16px 24px;gap:16px;
border-bottom:1px solid var(--border)}
.nav-links.open{display:flex}
.nav-toggle{display:block}
.nav-right{gap:12px}
.lang-btn span.lang-name{display:none}
.logo-sub{display:none !important}
}

/* ── HERO ── */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;
justify-content:center;overflow:hidden}
.hero-bg{position:absolute;top:0;left:0;width:120%;height:120%;
top:-10%;left:-10%;
background-size:cover;background-position:center;
opacity:.18;
animation:heroDrift 35s ease-in-out infinite alternate}
@keyframes heroDrift{
0%{transform:translate(0,0) scale(1)}
33%{transform:translate(2%,-1%) scale(1.03)}
66%{transform:translate(-1%,2%) scale(1.01)}
100%{transform:translate(1%,-2%) scale(1.04)}
}
.hero-overlay{position:absolute;top:0;left:0;width:100%;height:100%;
background:linear-gradient(180deg,rgba(10,14,23,.5) 0%,rgba(10,14,23,.88) 100%)}
.hero-content{position:relative;z-index:2;text-align:center;padding:0 24px;max-width:800px}
.hero h1{font-size:clamp(2.2rem,5.5vw,4rem);font-weight:700;
line-height:1.1;margin-bottom:20px;letter-spacing:-1px}
.hero h1 em{font-style:normal;color:var(--accent);
text-shadow:0 0 40px rgba(0,212,255,.35)}
.hero-brand{font-family:var(--mono);font-size:clamp(.9rem,2vw,1.1rem);
letter-spacing:3px;color:var(--muted);margin-bottom:24px;font-weight:300}
.hero-brand b{color:var(--accent);font-weight:700}
.hero p{font-size:clamp(1rem,2vw,1.25rem);color:var(--muted);
max-width:600px;margin:0 auto 36px}
.btn{display:inline-block;padding:14px 36px;border-radius:6px;
font-weight:600;font-size:.95rem;cursor:pointer;transition:all .25s;border:none;
letter-spacing:.5px}
.btn-primary{background:var(--accent);color:var(--bg);
box-shadow:0 0 24px rgba(0,212,255,.3)}
.btn-primary:hover{background:#33DFFF;box-shadow:0 0 40px rgba(0,212,255,.5);
transform:translateY(-2px)}
.btn-outline{background:transparent;color:var(--accent);
border:1.5px solid var(--accent)}
.btn-outline:hover{background:rgba(0,212,255,.1)}
.scroll-indicator{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);
z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px;
color:var(--muted);font-size:.75rem;letter-spacing:1px;animation:floatY 2s ease-in-out infinite}
.scroll-indicator .arrow{width:20px;height:20px;border-right:2px solid var(--muted);
border-bottom:2px solid var(--muted);transform:rotate(45deg)}
@keyframes floatY{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(8px)}}

/* ── SECTIONS ── */
section{padding:100px 24px}
.container{max-width:1200px;margin:0 auto}
.section-label{font-family:var(--mono);font-size:.8rem;color:var(--accent);
letter-spacing:3px;text-transform:uppercase;margin-bottom:12px}
.section-title{font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;
margin-bottom:16px;letter-spacing:-.5px}
.section-sub{color:var(--muted);font-size:1.05rem;max-width:640px;margin:0 auto 56px;text-align:center}

/* ── CAPABILITIES GRID ── */
.cap-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px}
.cap-card{background:var(--surface);border:1px solid var(--border);
border-radius:var(--radius);padding:28px 24px;
transition:border-color .3s,box-shadow .3s,transform .3s}
.cap-card:hover{border-color:var(--accent);
box-shadow:0 0 24px var(--accentGlow);transform:translateY(-3px)}
.cap-icon{font-size:1.6rem;margin-bottom:12px;display:block}
.cap-card h3{font-size:1rem;font-weight:600;margin-bottom:6px}
.cap-card p{font-size:.87rem;color:var(--muted);line-height:1.5}
.cap-check{color:var(--success);font-family:var(--mono);font-size:.75rem;
margin-top:10px;letter-spacing:.5px}

/* ── DETECTION PATTERNS ── */
.detect-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}
.detect-category{margin-bottom:40px}
.detect-category h3{font-size:1.1rem;font-weight:600;margin-bottom:20px;
display:flex;align-items:center;gap:8px}
.detect-category h3 .cat-icon{font-size:1.3rem}
.detect-category h3 .cat-count{font-family:var(--mono);font-size:.75rem;
color:var(--accent);background:rgba(0,212,255,.08);padding:2px 10px;border-radius:12px}
.detect-card{background:var(--surface);border:1px solid var(--border);
border-radius:var(--radius);padding:18px 16px;
transition:border-color .3s,box-shadow .3s,transform .3s;display:flex;gap:12px;align-items:flex-start}
.detect-card:hover{border-color:var(--accent);
box-shadow:0 0 20px var(--accentGlow);transform:translateY(-2px)}
.detect-card .d-icon{font-size:1.2rem;flex-shrink:0;margin-top:2px}
.detect-card .d-info h4{font-size:.88rem;font-weight:600;margin-bottom:3px}
.detect-card .d-info p{font-size:.85rem;color:var(--muted);line-height:1.4}

/* ── SECTORS ── */
.sector-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:36px}
.sector-tab{padding:10px 20px;border-radius:6px;background:var(--surface);
border:1px solid var(--border);color:var(--muted);font-size:.85rem;
font-weight:500;cursor:pointer;transition:all .25s}
.sector-tab.active,.sector-tab:hover{border-color:var(--accent);
color:var(--accent);background:rgba(0,212,255,.06)}
.sector-panel{display:none;animation:fadeUp .4s ease}
.sector-panel.active{display:block}
.sector-features{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
.sf-item{display:flex;gap:12px;align-items:flex-start;padding:16px;
border-radius:var(--radius);background:rgba(17,24,39,.6);border:1px solid transparent;
transition:border-color .3s}
.sf-item:hover{border-color:var(--border)}
.sf-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);
flex-shrink:0;margin-top:7px;box-shadow:0 0 8px rgba(0,212,255,.4)}
.sf-item h4{font-size:.9rem;font-weight:600;margin-bottom:2px}
.sf-item p{font-size:.8rem;color:var(--muted)}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── WHY LAYER.ONE ── */
.compare-table{width:100%;border-collapse:collapse;font-size:.85rem}
.compare-table thead th{text-align:left;padding:14px 12px;font-size:.75rem;
color:var(--accent);letter-spacing:1px;text-transform:uppercase;font-family:var(--mono);
border-bottom:2px solid var(--accent);font-weight:600}
.compare-table thead th:first-child{color:var(--muted)}
.compare-table thead th.hl{background:rgba(0,212,255,.04)}
.compare-table tbody td{padding:12px;border-bottom:1px solid var(--border);
color:var(--muted);vertical-align:middle}
.compare-table tbody td:first-child{color:var(--text);font-weight:500;font-size:.87rem}
.compare-table tbody td.hl{background:rgba(0,212,255,.03)}
.compare-table .check{color:var(--success);font-weight:700;font-size:1rem}
.compare-table .partial{color:var(--warning);font-weight:700;font-size:1rem}
.compare-table .cross{color:var(--danger);font-weight:700;font-size:1rem}
.compare-table-wrapper{overflow-x:auto;border:1px solid var(--border);border-radius:var(--radius);background:var(--surface)}
@media(max-width:768px){.compare-table{font-size:.75rem}
.compare-table thead th,.compare-table tbody td{padding:8px 6px}}

/* ── PIPELINE ── */
.pipeline{display:flex;gap:0;overflow-x:auto;padding-bottom:16px}
.pipe-step{flex:1;min-width:160px;text-align:center;position:relative;padding:24px 12px}
.pipe-icon{width:56px;height:56px;border-radius:50%;background:var(--surface);
border:2px solid var(--border);display:flex;align-items:center;justify-content:center;
font-size:1.4rem;margin:0 auto 14px;transition:all .6s}
.pipe-step.lit .pipe-icon{border-color:var(--accent);
box-shadow:0 0 20px var(--accentGlow);background:rgba(0,212,255,.08)}
.pipe-step h4{font-size:.85rem;font-weight:600;margin-bottom:4px}
.pipe-step p{font-size:.75rem;color:var(--muted)}
.pipe-arrow{position:absolute;right:-12px;top:46px;color:var(--border);
font-size:1.2rem;transition:color .6s}
.pipe-step.lit .pipe-arrow{color:var(--accent)}
.pipe-step:last-child .pipe-arrow{display:none}
.tech-highlights{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
gap:16px;margin-top:48px}
.th-card{padding:20px;border-left:3px solid var(--accent);
background:var(--surface);border-radius:0 var(--radius) var(--radius) 0}
.th-card h4{font-size:.9rem;font-weight:600;margin-bottom:4px}
.th-card p{font-size:.8rem;color:var(--muted)}

/* ── ARCHITECTURE DIAGRAM ── */
.arch-flow{display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:wrap;padding:20px 0}
.arch-node{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
padding:20px 16px;text-align:center;min-width:140px;max-width:170px;
transition:all .3s;position:relative}
.arch-node:hover{border-color:var(--accent);box-shadow:0 0 24px var(--accentGlow);transform:translateY(-3px)}
.arch-node .a-icon{font-size:1.6rem;margin-bottom:8px;display:block}
.arch-node h4{font-size:.82rem;font-weight:600;margin-bottom:4px}
.arch-node p{font-size:.7rem;color:var(--muted);line-height:1.3}
.arch-arrow{color:var(--accent);font-size:1.4rem;margin:0 6px;flex-shrink:0;
font-family:var(--mono);opacity:.6}
.arch-layer{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:24px;flex-wrap:wrap}
.arch-layer .arch-node{flex:0 1 160px}
.arch-layer .arch-arrow{flex:0 0 auto}
@media(max-width:1100px){
.arch-layer{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;justify-items:center}
.arch-layer .arch-arrow{display:none}
.arch-layer .arch-node{flex:none;width:100%;max-width:220px}
}
@media(max-width:700px){
.arch-layer{grid-template-columns:repeat(2,1fr)}
}
.arch-section-label{font-family:var(--mono);font-size:.7rem;color:var(--accent);
letter-spacing:2px;text-transform:uppercase;text-align:center;margin-bottom:16px;opacity:.6}
.arch-bottom{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
gap:16px;margin-top:32px;padding-top:24px;border-top:1px solid var(--border)}
.arch-infra{padding:16px;background:rgba(0,212,255,.03);border:1px solid var(--border);
border-radius:var(--radius);text-align:center}
.arch-infra .a-icon{font-size:1.2rem;margin-bottom:6px;display:block}
.arch-infra h4{font-size:.8rem;font-weight:600;margin-bottom:2px}
.arch-infra p{font-size:.7rem;color:var(--muted)}
@media(max-width:768px){
.arch-layer{grid-template-columns:1fr !important}
.arch-layer .arch-arrow{display:none}
.arch-node{min-width:200px;max-width:100%}
}

/* ── NUMBERS ── */
.numbers-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:24px;text-align:center}
.num-card{padding:32px 16px}
.num-value{font-size:clamp(2rem,4vw,3rem);font-weight:700;color:var(--accent);
font-family:var(--mono);letter-spacing:-1px;
text-shadow:0 0 30px rgba(0,212,255,.25)}
.num-label{font-size:.85rem;color:var(--muted);margin-top:6px}

/* ── CERTS ── */
.certs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:20px;text-align:center}
.cert-badge{padding:28px 16px;background:var(--surface);border:1px solid var(--border);
border-radius:var(--radius);transition:all .3s}
.cert-badge:hover{border-color:var(--accent);box-shadow:0 0 20px var(--accentGlow)}
.cert-shield{width:52px;height:60px;margin:0 auto 12px;position:relative}
.cert-shield svg{width:100%;height:100%}
.cert-badge h4{font-size:.85rem;font-weight:600;margin-bottom:2px}
.cert-badge p{font-size:.72rem;color:var(--muted)}

/* ── CONTACT FORM ── */
.contact-section{padding:80px 24px;
background:linear-gradient(180deg,var(--bg) 0%,rgba(0,212,255,.04) 100%)}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;max-width:1000px;margin:0 auto}
.contact-info h2{font-size:clamp(1.6rem,3vw,2.4rem);font-weight:700;margin-bottom:12px}
.contact-info p{color:var(--muted);margin-bottom:24px;font-size:1.05rem}
.contact-info .ci-item{display:flex;align-items:center;gap:10px;margin-bottom:14px;
color:var(--muted);font-size:.9rem}
.contact-info .ci-item .ci-icon{color:var(--accent);font-size:1.1rem}
.contact-form{display:flex;flex-direction:column;gap:16px}
.contact-form input,.contact-form textarea{background:var(--surface);
border:1px solid var(--border);border-radius:6px;padding:14px 16px;
color:var(--text);font-family:var(--font);font-size:.9rem;transition:border-color .2s;outline:none}
.contact-form input:focus,.contact-form textarea:focus{border-color:var(--accent)}
.contact-form input::placeholder,.contact-form textarea::placeholder{color:var(--muted);opacity:.6}
.contact-form textarea{resize:vertical;min-height:100px}
.contact-form .btn{width:100%;text-align:center}
.form-note{font-size:.75rem;color:var(--muted);text-align:center;margin-top:4px}
@media(max-width:768px){.contact-grid{grid-template-columns:1fr;gap:32px}}

/* ── FOOTER ── */
.footer-bottom{text-align:center;padding:24px;border-top:1px solid var(--border);
color:var(--muted);font-size:.75rem}

/* ── NETWORK TRACE ── */
/* ── NETWORK TRACE ── */
.trace-section{padding:100px 24px;position:relative;overflow:hidden}
.trace-section .container{max-width:1200px;margin:0 auto;text-align:center}
.trace-demo{margin:48px auto 56px;max-width:800px}
.trace-search{display:inline-flex;align-items:center;gap:10px;background:var(--surface);
border:1px solid var(--border);border-radius:var(--radius);padding:14px 24px;font-size:1rem;
color:var(--text);font-family:var(--mono);min-width:340px;transition:border-color .4s,box-shadow .4s}
.trace-search.active{border-color:var(--accent);box-shadow:0 0 20px rgba(0,212,255,.15)}
.trace-search .search-icon{color:var(--accent);font-size:1.1rem}
.trace-cursor{display:inline-block;width:2px;height:1.1em;background:var(--accent);
animation:blink-cursor .7s step-end infinite;vertical-align:text-bottom;margin-left:1px}
@keyframes blink-cursor{50%{opacity:0}}

/* Graph area — larger than scenario graphs */
.trace-graph{position:relative;width:100%;height:500px;margin:24px auto 0;
border:1px solid rgba(148,163,184,.12);border-radius:12px;
background:
  radial-gradient(circle at 50% 50%, rgba(0,212,255,.03) 0%, transparent 70%),
  linear-gradient(rgba(148,163,184,.04) 1px, transparent 1px),
  linear-gradient(90deg, rgba(148,163,184,.04) 1px, transparent 1px);
background-size:100% 100%, 40px 40px, 40px 40px;
overflow:hidden}
.trace-graph::before{content:'● SCANNING';position:absolute;top:16px;left:20px;
font-family:var(--mono);font-size:.65rem;letter-spacing:.08em;
color:var(--accent);opacity:.5;z-index:5;
animation:trace-frame-pulse 2s ease-in-out infinite}
.trace-graph::after{content:'';position:absolute;inset:0;
border-radius:12px;pointer-events:none;
background:radial-gradient(ellipse at 50% 0%, rgba(0,212,255,.06) 0%, transparent 60%)}
@keyframes trace-frame-pulse{0%,100%{opacity:.5}50%{opacity:.2}}
.trace-graph.has-nodes::before{opacity:0;transition:opacity .5s}
.trace-lines{position:absolute;inset:0;width:100%;height:100%;z-index:1}
.trace-lines line{stroke:rgba(148,163,184,.15);stroke-width:1.5;
opacity:0;transition:opacity .6s ease,stroke .5s ease,stroke-width .3s}
.trace-lines line.visible{opacity:1}
.trace-lines line.flagged-red{stroke:var(--danger);stroke-width:2.5;
filter:drop-shadow(0 0 4px rgba(239,68,68,.4))}
.trace-lines line.cross{stroke-dasharray:6,4}

/* Override node sizes for trace section */
.trace-graph .graph-node.trace-nd{width:32px;height:32px;font-size:.6rem;
opacity:0;transform:scale(0);transition:opacity .5s ease,transform .5s cubic-bezier(.34,1.56,.64,1);z-index:3}
.trace-graph .graph-node.trace-nd.visible{opacity:1;transform:scale(1)}
.trace-graph .graph-node.center.trace-nd{width:44px;height:44px;font-size:.7rem;
box-shadow:0 0 16px rgba(239,68,68,.5)}
.trace-graph .graph-node.trace-r2{width:26px;height:26px;font-size:.55rem}

/* Node pulse effect */
@keyframes trace-pulse{0%,100%{box-shadow:0 0 16px rgba(239,68,68,.4)}50%{box-shadow:0 0 28px rgba(239,68,68,.7)}}
.trace-graph .graph-node.trace-nd.pulsing{animation:trace-pulse 1.5s ease infinite}

/* Node labels */
.trace-nlabel{position:absolute;font-size:.6rem;font-family:var(--mono);color:var(--muted);
white-space:nowrap;transform:translateX(-50%);z-index:4;
opacity:0;transition:opacity .4s ease;pointer-events:none}
.trace-nlabel.visible{opacity:1}

/* Amount labels on flagged edges */
.trace-amount{position:absolute;font-size:.65rem;font-family:var(--mono);font-weight:700;
color:var(--danger);background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);
border-radius:4px;padding:2px 8px;z-index:5;opacity:0;transform:translateX(-50%) scale(0.8);
transition:opacity .4s ease,transform .4s ease;pointer-events:none}
.trace-amount.visible{opacity:1;transform:translateX(-50%) scale(1)}

/* Detection badges */
.trace-detect{display:inline-block;background:rgba(239,68,68,.1);
border:1px solid rgba(239,68,68,.3);border-radius:6px;padding:10px 20px;
font-size:.8rem;color:var(--danger);font-weight:600;font-family:var(--mono);
opacity:0;transform:translateY(10px);transition:opacity .5s ease,transform .5s ease;
margin-top:16px;pointer-events:none}
.trace-detect.visible{opacity:1;transform:translateY(0)}
.trace-detect-secondary{background:rgba(0,212,255,.08);border-color:rgba(0,212,255,.3);
color:var(--accent);margin-left:12px}
.trace-detect-secondary strong{font-size:1.1rem}
.trace-detect-sar{background:rgba(16,185,129,.08);border-color:rgba(16,185,129,.3);
color:var(--success);margin-left:12px}

/* Capability cards */
.trace-capabilities{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;text-align:left}
.trace-cap-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
padding:24px;transition:border-color .3s,transform .3s}
.trace-cap-card:hover{border-color:rgba(0,212,255,.3);transform:translateY(-2px)}
.trace-cap-card .cap-emoji{font-size:1.6rem;margin-bottom:12px;display:block}
.trace-cap-card h4{font-size:.95rem;font-weight:700;margin-bottom:8px;color:var(--text)}
.trace-cap-card p{font-size:.85rem;color:var(--muted);line-height:1.6}

/* Responsive */
@media(max-width:900px){
.trace-capabilities{grid-template-columns:repeat(2,1fr)}
.trace-graph{height:400px}
.trace-search{min-width:280px;font-size:.9rem;padding:12px 18px}
.trace-detect{font-size:.7rem;padding:8px 14px;display:block;margin:8px auto 0}
.trace-detect-secondary,.trace-detect-sar{margin-left:0}
}
@media(max-width:600px){
.trace-capabilities{grid-template-columns:1fr}
.trace-graph{height:320px}
.trace-search{min-width:240px;font-size:.85rem;padding:10px 16px}
.trace-graph .graph-node.trace-nd{width:24px;height:24px;font-size:.5rem}
.trace-graph .graph-node.center.trace-nd{width:34px;height:34px}
.trace-graph .graph-node.trace-r2{width:20px;height:20px;font-size:.45rem}
.trace-nlabel{font-size:.5rem}
.trace-amount{font-size:.55rem;padding:1px 5px}
}
/* Scenario dots indicator */
.trace-scenario-indicator{display:flex;justify-content:center;gap:8px;margin:16px 0 0}
.trace-dot{width:8px;height:8px;border-radius:50%;background:rgba(148,163,184,.25);
transition:background .4s ease,transform .4s ease}
.trace-dot.active{background:var(--accent);transform:scale(1.3)}


/* ── DIVIDER ── */
.section-divider{height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);
margin:0 auto;max-width:600px}

/* ── REVEAL ── */
.reveal{opacity:1;transform:translateY(0);transition:opacity .7s,transform .7s}
.reveal.hidden{opacity:0;transform:translateY(30px)}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── RESPONSIVE ── */
@media(max-width:1024px){
section{padding:70px 20px}
.cap-grid{grid-template-columns:repeat(auto-fill,minmax(260px,1fr))}
.detect-grid{grid-template-columns:repeat(auto-fill,minmax(200px,1fr))}
.sector-features{grid-template-columns:1fr}
.numbers-grid{grid-template-columns:repeat(3,1fr)}
.certs-grid{grid-template-columns:repeat(4,1fr)}
}
@media(max-width:768px){
section{padding:60px 16px}
.cap-grid{grid-template-columns:1fr}
.detect-grid{grid-template-columns:1fr 1fr}
.numbers-grid{grid-template-columns:repeat(2,1fr)}
.certs-grid{grid-template-columns:repeat(2,1fr)}
.pipeline{flex-direction:column;align-items:center}
.pipe-step{min-width:auto;width:100%}
.pipe-arrow{display:none !important}
.sector-tabs{gap:6px}
.sector-tab{padding:8px 14px;font-size:.8rem}
.hero h1{font-size:clamp(1.8rem,6vw,2.5rem)}
.hero-brand{letter-spacing:2px;font-size:.8rem}
.section-title{font-size:clamp(1.4rem,4vw,2rem)}
.tech-highlights{grid-template-columns:1fr}
}
@media(max-width:480px){
.detect-grid{grid-template-columns:1fr}
.numbers-grid{grid-template-columns:1fr 1fr}
.certs-grid{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>

