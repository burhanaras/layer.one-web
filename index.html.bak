];

var currentScenario = 0;
var allTimers = [];
var allIntervals = [];
var createdEls = [];

function sched(fn, ms){ allTimers.push(setTimeout(fn, ms)); }

function clearAll(){
  allTimers.forEach(clearTimeout);
  allTimers = [];
  allIntervals.forEach(clearInterval);
  allIntervals = [];
  createdEls.forEach(function(el){ if(el && el.parentNode) el.parentNode.removeChild(el); });
  createdEls = [];
  svgLines.innerHTML = '';
  typedEl.textContent = '';
  searchEl.classList.remove('active');
  if(cursorEl) cursorEl.style.display = 'inline-block';
  [detect1, detect2, detect3].forEach(function(d){ if(d){ d.classList.remove('visible'); d.style.opacity=''; d.style.transition=''; }});
  if(riskNum) riskNum.textContent = '0';
  traceGraph.classList.remove('has-nodes');
  traceGraph.style.opacity = '1';
  traceGraph.style.transition = 'none';
  searchEl.style.opacity = '1';
  searchEl.style.transition = 'none';
}

/* Update scenario dots */
function updateDots(idx){
  for(var i=0;i<3;i++){
    var dot = document.getElementById('traceDot'+i);
    if(dot){ dot.classList.toggle('active', i===idx); }
  }
}

/* Create a DOM node */
function makeNode(nd, isCenter, isR2){
  var sz = isCenter ? 44 : (isR2 ? 26 : 32);
  var offset = sz / 2;
  var div = document.createElement('div');
  div.className = 'graph-node ' + nd.type + ' trace-nd' + (isCenter ? ' center' : '') + (isR2 ? ' trace-r2' : '');
  div.style.cssText = 'left:calc('+nd.x+'% - '+offset+'px);top:calc('+nd.y+'% - '+offset+'px)';
  div.textContent = nd.icon;
  traceGraph.appendChild(div);
  createdEls.push(div);

  var lbl = document.createElement('span');
  lbl.className = 'trace-nlabel';
  var lblOffset = isCenter ? 28 : (isR2 ? 18 : 20);
  lbl.style.cssText = 'left:'+nd.x+'%;top:calc('+nd.y+'% + '+lblOffset+'px)';
  lbl.textContent = nd.label;
  traceGraph.appendChild(lbl);
  createdEls.push(lbl);

  return {node: div, label: lbl};
}

/* Create an SVG line */
function makeLine(x1,y1,x2,y2,isCross){
  var line = document.createElementNS('http://www.w3.org/2000/svg','line');
  line.setAttribute('x1',x1+'%');
  line.setAttribute('y1',y1+'%');
  line.setAttribute('x2',x2+'%');
  line.setAttribute('y2',y2+'%');
  if(isCross) line.classList.add('cross');
  svgLines.appendChild(line);
  return line;
}

/* Create amount label */
function makeAmount(amt){
  var span = document.createElement('span');
  span.className = 'trace-amount';
  span.style.cssText = 'left:'+amt.x+'%;top:'+amt.y+'%';
  span.textContent = amt.text;
  traceGraph.appendChild(span);
  createdEls.push(span);
  return span;
}

function showEl(el, cls){ if(el) el.classList.add(cls || 'visible'); }

function animateRisk(target, duration){
  if(!riskNum) return;
  var start = 0; var step = Math.ceil(target / (duration / 30));
  var iv = setInterval(function(){
    start += step;
    if(start >= target){ start = target; clearInterval(iv); }
    riskNum.textContent = String(start);
  }, 30);
  allIntervals.push(iv);
}

function typeText(text, cb){
  searchEl.classList.add('active');
  var idx = 0;
  var iv = setInterval(function(){
    if(idx < text.length){
      typedEl.textContent += text[idx]; idx++;
    } else {
      clearInterval(iv);
      if(cursorEl) cursorEl.style.display='none';
      if(cb) cb();
    }
  }, 100);
  allIntervals.push(iv);
}

function runCycle(){
  clearAll();
  var sc = SCENARIOS[currentScenario];
  updateDots(currentScenario);

  /* Build DOM elements for this scenario */
  var centerEls = makeNode(sc.center, true, false);
  var r1Els = sc.ring1.map(function(nd){ return makeNode(nd, false, false); });
  var r2Els = sc.ring2.map(function(nd){ return makeNode(nd, false, true); });

  /* Build edges center → ring1 */
  var edgesR1 = sc.ring1.map(function(nd){
    return makeLine(sc.center.x, sc.center.y, nd.x, nd.y, false);
  });

  /* Build edges ring1 → ring2 */
  var edgesR2 = sc.ring2.map(function(nd){
    var parent = sc.ring1[nd.parent];
    return makeLine(parent.x, parent.y, nd.x, nd.y, false);
  });

  /* Build cross-edges */
  var edgesCross = sc.crossEdges.map(function(e){
    return makeLine(e.from.x, e.from.y, e.to.x, e.to.y, true);
  });

  /* Build amount labels */
  var amountEls = sc.amounts.map(function(a){ return makeAmount(a); });

  /* Set badge text */
  if(badgeText) badgeText.textContent = sc.badge;

  var t = 0;

  /* ═══ Phase 1: Typewriter (0–3s) ═══ */
  sched(function(){ typeText(sc.searchText, function(){}); }, 0);
  t = 3000;

  /* ═══ Phase 2: Seed entity (3–5s) ═══ */
  sched(function(){
    traceGraph.classList.add('has-nodes');
    showEl(centerEls.node);
    showEl(centerEls.label);
    centerEls.node.classList.add('pulsing');
  }, t);
  t += 2000;

  /* ═══ Phase 3: Ring 1 — staggered (5–12s) ═══ */
  r1Els.forEach(function(els, i){
    var edgeDelay = t + i * 1000;
    var nodeDelay = edgeDelay + 400;
    sched(function(){ showEl(edgesR1[i]); }, edgeDelay);
    sched(function(){
      showEl(els.node);
      showEl(els.label);
    }, nodeDelay);
  });
  t += sc.ring1.length * 1000;

  /* ═══ Phase 4: Ring 2 + cross edges (12–20s) ═══ */
  r2Els.forEach(function(els, i){
    var edgeDelay = t + i * 1100;
    var nodeDelay = edgeDelay + 400;
    sched(function(){ showEl(edgesR2[i]); }, edgeDelay);
    sched(function(){
      showEl(els.node);
      showEl(els.label);
    }, nodeDelay);
  });
  t += sc.ring2.length * 1100;

  sched(function(){
    edgesCross.forEach(function(e, i){
      sched(function(){ showEl(e); }, i * 400);
    });
  }, t);
  t += edgesCross.length * 400 + 500;

  /* ═══ Phase 5: Suspicious activity (20–27s) ═══ */
  sched(function(){
    if(centerEls.node) centerEls.node.classList.remove('pulsing');
  }, t);

  edgesCross.forEach(function(e, i){
    sched(function(){ if(e) e.classList.add('flagged-red'); }, t + i * 800);
  });
  amountEls.forEach(function(a, i){
    sched(function(){ showEl(a); }, t + i * 800 + 400);
  });

  /* Pulse some ring1 nodes */
  var pulseCount = Math.min(4, sc.ring1.length);
  var pulseNodes = [];
  for(var pi=0; pi<pulseCount; pi++) pulseNodes.push(r1Els[pi]);
  sched(function(){
    pulseNodes.forEach(function(els){ if(els && els.node) els.node.classList.add('pulsing'); });
  }, t + 1200);
  sched(function(){
    pulseNodes.forEach(function(els){ if(els && els.node) els.node.classList.remove('pulsing'); });
  }, t + 3500);
  t += edgesCross.length * 800 + 2000;

  /* ═══ Phase 6: Detection results (27–33s) ═══ */
  sched(function(){ showEl(detect1); }, t);
  sched(function(){
    showEl(detect2);
    animateRisk(sc.riskScore, 1200);
  }, t + 1500);
  sched(function(){ showEl(detect3); }, t + 3000);
  t += 4500;

  /* ═══ Phase 7: Hold & fade (33–38s) ═══ */
  sched(function(){
    traceGraph.style.transition = 'opacity 1.2s ease';
    traceGraph.style.opacity = '0';
    searchEl.style.transition = 'opacity 1.2s ease';
    searchEl.style.opacity = '0';
    [detect1, detect2, detect3].forEach(function(d){
      if(d){ d.style.transition = 'opacity 1.2s ease'; d.style.opacity = '0'; }
    });
  }, t + 3000);

  /* Next scenario */
  sched(function(){
    currentScenario = (currentScenario + 1) % SCENARIOS.length;
    sched(runCycle, 800);
  }, t + 4500);
}

/* IntersectionObserver — start when visible */
var running = false;
var section = document.getElementById('network-trace');
if (!section) return;

if ('IntersectionObserver' in window) {
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if (entry.isIntersecting && !running) {
        running = true;
        sched(runCycle, 400);
      }
      if (!entry.isIntersecting && running) {
        running = false;
        clearAll();
        currentScenario = 0;
        updateDots(0);
      }
    });
  }, {threshold: 0.15});
  obs.observe(section);
} else {
  sched(runCycle, 1000);
}
})();

</script>
</body>
</html>
