var currentLang = 'en';

function setLang(lang) {
currentLang = lang;
var t = i18n[lang];
if (!t) return;
// Text content
document.querySelectorAll('[data-i18n]').forEach(function(el) {
var key = el.getAttribute('data-i18n');
if (t[key] !== undefined) el.innerHTML = t[key];
});
// Placeholders
document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
var key = el.getAttribute('data-i18n-ph');
if (t[key] !== undefined) el.placeholder = t[key];
});
// Update lang selector button
var flagMap = {en:'🇬🇧',tr:'🇹🇷'};
var nameMap = {en:'EN',tr:'TR'};
document.querySelector('#langBtn .flag').textContent = flagMap[lang] || '🌐';
document.querySelector('#langBtn .lang-name').textContent = nameMap[lang] || lang.toUpperCase();
document.querySelectorAll('.lang-option').forEach(function(o) {
o.classList.toggle('active', o.getAttribute('data-lang') === lang);
});
document.documentElement.lang = lang;
}

/* ── LANG SELECTOR ── */
var langSel = document.getElementById('langSelector');
var langBtn = document.getElementById('langBtn');
langBtn.addEventListener('click', function(e) {
e.stopPropagation();
langSel.classList.toggle('open');
});
document.querySelectorAll('.lang-option').forEach(function(opt) {
opt.addEventListener('click', function() {
setLang(opt.getAttribute('data-lang'));
langSel.classList.remove('open');
});
});
document.addEventListener('click', function() { langSel.classList.remove('open'); });

/* ── NAV TOGGLE ── */
var tog=document.getElementById('navToggle');
var links=document.getElementById('navLinks');
tog.addEventListener('click',function(){links.classList.toggle('open')});
links.addEventListener('click',function(e){
if(e.target.tagName==='A')links.classList.remove('open');
});

/* ── SECTOR TABS ── */
var tabs=document.querySelectorAll('.sector-tab');
var panels=document.querySelectorAll('.sector-panel');
tabs.forEach(function(tab){
tab.addEventListener('click',function(){
tabs.forEach(function(t){t.classList.remove('active')});
panels.forEach(function(p){p.classList.remove('active')});
tab.classList.add('active');
var s=document.getElementById('sector-'+tab.getAttribute('data-sector'));
if(s)s.classList.add('active');
});
});

/* ── PIPELINE ANIMATION ── */
function animatePipeline(){
var steps=document.querySelectorAll('.pipe-step');
var idx=0;
function lightNext(){
if(idx<steps.length){steps[idx].classList.add('lit');idx++;setTimeout(lightNext,400)}
else{setTimeout(function(){steps.forEach(function(s){s.classList.remove('lit')});idx=0;lightNext()},3000)}
}
var io=new IntersectionObserver(function(entries){
entries.forEach(function(e){if(e.isIntersecting){lightNext();io.disconnect()}});
},{threshold:.3});
var sec=document.getElementById('how-it-works');
if(sec)io.observe(sec);
}
animatePipeline();

/* ── NUMBER COUNTER ── */
function animateCounters(){
var counters=document.querySelectorAll('.counter');
counters.forEach(function(el){
var io=new IntersectionObserver(function(entries){
entries.forEach(function(e){
if(e.isIntersecting){
var tgt=el.getAttribute('data-target');
var sfx=el.getAttribute('data-suffix')||'';
var hasLT=tgt.charAt(0)==='<';
var prefix=hasLT?'<':'';
var clean=tgt.replace('<','');
var unit='';
if(clean.match(/[MmKk]$/)){unit=clean.slice(-1).toUpperCase();clean=clean.slice(0,-1)}
var num=parseFloat(clean);
var isInt=Number.isInteger(num);
var dur=1200,start=null;
function step(ts){
if(!start)start=ts;
var p=Math.min((ts-start)/dur,1);
var ease=1-Math.pow(1-p,3);
var cur=(num*ease);
if(isInt)el.textContent=prefix+Math.round(cur)+unit+sfx;
else el.textContent=prefix+cur.toFixed(2)+unit+sfx;
if(p<1)requestAnimationFrame(step);
else el.textContent=prefix+num+unit+sfx;
}
requestAnimationFrame(step);
io.disconnect();
}});
},{threshold:.5});
io.observe(el);
});
}
animateCounters();

/* ── REVEAL ON SCROLL ── */
var reveals=document.querySelectorAll('.reveal');
reveals.forEach(function(el){el.classList.add('hidden')});
var revIO=new IntersectionObserver(function(entries){
entries.forEach(function(e){if(e.isIntersecting){e.target.classList.remove('hidden');e.target.classList.add('visible');revIO.unobserve(e.target)}});
},{threshold:.1,rootMargin:'0px 0px -40px 0px'});
reveals.forEach(function(el){revIO.observe(el)});

/* ── ACTIVE NAV HIGHLIGHT ── */
var sections=document.querySelectorAll('section[id]');
var navAs=document.querySelectorAll('.nav-links a[href^="#"]');
var navIO=new IntersectionObserver(function(entries){
entries.forEach(function(e){
if(e.isIntersecting){
var id=e.target.getAttribute('id');
navAs.forEach(function(a){a.classList.remove('active');
if(a.getAttribute('href')==='#'+id)a.classList.add('active');
});
}});
},{threshold:.2,rootMargin:'-64px 0px -50% 0px'});
sections.forEach(function(s){navIO.observe(s)});

/* ── SCENARIO CAROUSEL ── */

var scTabs=document.querySelectorAll('.scenario-tab');
var scPanels=document.querySelectorAll('.scenario-panel');
scTabs.forEach(function(tab){
tab.addEventListener('click',function(){
scTabs.forEach(function(t){t.classList.remove('active')});
scPanels.forEach(function(p){p.classList.remove('active')});
tab.classList.add('active');
var idx=tab.getAttribute('data-scenario');
var panel=document.querySelector('[data-scenario-panel="'+idx+'"]');
if(panel)panel.classList.add('active');
});
});

})();

/* ── CONTACT FORM HANDLER ── */
function handleFormSubmit(e) {
e.preventDefault();
var form = document.getElementById('contactForm');
var btn = form.querySelector('.btn');
var origText = btn.textContent;
btn.textContent = currentLang === 'tr' ? 'Gönderiliyor...' : 'Sending...';
btn.style.opacity = '.6';
btn.disabled = true;
setTimeout(function() {
btn.textContent = currentLang === 'tr' ? '✓ Gönderildi!' : '✓ Sent!';
btn.style.opacity = '1';
btn.style.background = 'var(--success)';
form.reset();
setTimeout(function() {
btn.textContent = origText;
btn.style.background = '';
btn.disabled = false;
}, 3000);
}, 1500);
return false;
}
</script>
<script>
/* ── Network Trace Cinematic Animation — 3 Scenarios ── */
(function(){
var typedEl = document.getElementById('traceTyped');
var cursorEl = document.getElementById('traceCursor');
var searchEl = document.getElementById('traceSearch');
var traceGraph = document.getElementById('traceGraph');
var svgLines = document.getElementById('traceLines');
var detect1 = document.getElementById('traceDetect1');
var detect2 = document.getElementById('traceDetect2');
var detect3 = document.getElementById('traceDetect3');
var riskNum = document.getElementById('traceRiskNum');
var badgeText = document.getElementById('traceBadgeText');
if (!typedEl || !searchEl || !traceGraph) return;

/* ─── 3 SCENARIO DATA ─── */
var SCENARIOS = [
/* ═══ Scenario 1: Meridian Holdings — Layering ═══ */
{
